name: Build Unit History Index

on:
  workflow_dispatch:
  push:
    paths:
      - "unit-history/events/**"
      - "scripts/build_unit_history_index.py"

permissions:
  contents: write

jobs:
  build-index:
    runs-on: ubuntu-latest

    steps:
      - name: Check out repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Build unit history index
        run: python scripts/build_unit_history_index.py

      - name: Commit updated JSON
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add data/unit_history_index.json
          git diff --cached --quiet || git commit -m "Update unit history index"
          git push
